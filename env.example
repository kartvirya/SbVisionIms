# Django Settings
SECRET_KEY=your-secret-key-here-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,ip-address

# If nginx serves the app under a path (e.g. location /ims/), set this and use rewrite on the proxy:
# FORCE_SCRIPT_NAME=/ims

# Comma-separated origins for CSRF when using HTTPS (required for Django 4+ on forms/admin):
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Database Configuration (PostgreSQL)
DB_NAME=inventory_db
DB_USER=inventory_user
DB_PASSWORD=your-database-password
DB_HOST=localhost
DB_PORT=5432

# SSL Settings (set to True if using SSL)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Email Configuration (Optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
